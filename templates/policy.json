{
  "queue": {
    "assignees": ["@me"],
    "labels": ["dark-factory"],
    "match": "any"
  },
  "repositories": ["owner/repo"],
  "merge": { "mode": "manual" },
  "providers": {
    "implement": ["claude"],
    "review": ["claude"],
    "quota_domains": {
      "claude": "anthropic:personal"
    }
  },
  "limits": {
    "max_turns": 40,
    "max_check_repairs": 5
  },
  "denied_commands": [],
  "denied_paths": [".env", ".env.*", ".github/workflows"]
}
