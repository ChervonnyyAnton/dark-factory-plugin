#!/usr/bin/env python3
import copy
import datetime as dt
import fcntl
import json
import os
import subprocess
import sys
import tempfile
from collections import namedtuple
from pathlib import Path
from urllib.parse import urlparse


ROOT = Path(__file__).resolve().parents[1]
PROVIDERS = {
    "claude": ("claude", "-p", "--dangerously-skip-permissions"),
    "codex": (
        "codex",
        "exec",
        "--dangerously-bypass-approvals-and-sandbox",
        "-",
    ),
}
AttemptResult = namedtuple(
    "AttemptResult",
    "status returncode run_dir stdout_path stderr_path result_path handoff_path",
)

DEFAULT_STATE = {
    "version": 1,
    "requested": "stopped",
    "phase": "idle",
    "project": None,
    "issue": None,
    "pr": None,
    "branch": None,
    "head_sha": None,
    "attempts": {},
    "cooldowns": {},
    "next_wake_at": None,
    "updated_at": None,
}


def load_policy(root):
    return json.loads((Path(root) / ".dark-factory" / "policy.json").read_text())


def resolve_assignees(policy, run):
    raw = policy.get("queue", {}).get("assignees", [])
    me_login = None
    resolved = []
    for assignee in raw:
        if assignee == "@me":
            if me_login is None:
                result = run(["gh", "api", "user", "-q", ".login"])
                me_login = result.stdout.strip()
            resolved.append(me_login)
        else:
            resolved.append(assignee)
    return resolved


def issue_matches(issue, policy, assignees):
    queue = policy.get("queue", {})
    labels = queue.get("labels", [])
    match_mode = queue.get("match", "any")

    issue_logins = {a.get("login") for a in issue.get("assignees", [])}
    issue_labels = {label.get("name") for label in issue.get("labels", [])}

    assignee_match = bool(issue_logins & set(assignees))
    label_match = bool(issue_labels & set(labels))

    if match_mode == "all":
        return assignee_match and label_match
    return assignee_match or label_match


def _repository_from_origin(run):
    remote = run(["git", "remote", "get-url", "origin"]).stdout.strip()
    if "://" in remote:
        repository = urlparse(remote).path.lstrip("/")
    else:
        repository = remote.rsplit(":", 1)[-1]
    return repository.rstrip("/").removesuffix(".git")


def list_matching_issues(run, policy):
    repositories = policy.get("repositories") or [_repository_from_origin(run)]
    assignees = resolve_assignees(policy, run)
    matches = []
    fields = "number,title,url,createdAt,assignees,labels"
    for repository in repositories:
        result = run([
            "gh", "issue", "list",
            "--repo", repository,
            "--state", "open",
            "--json", fields,
        ])
        for issue in json.loads(result.stdout):
            issue = dict(issue, repository=repository)
            if issue_matches(issue, policy, assignees):
                matches.append(issue)
    return matches


def select_issue(issues):
    return min(
        issues,
        key=lambda issue: (
            issue["createdAt"],
            issue["repository"],
            issue["number"],
        ),
        default=None,
    )


def reconcile(state, run, policy):
    reconciled = copy.deepcopy(state)
    current = reconciled["issue"]
    if isinstance(current, dict):
        repository = current["repository"]
        number = current["number"]
    else:
        repository = reconciled["repository"]
        number = current
    fields = "number,title,url,createdAt,assignees,labels"
    result = run([
        "gh", "issue", "view", str(number),
        "--repo", repository,
        "--json", fields,
    ])
    issue = dict(json.loads(result.stdout), repository=repository)
    if not issue_matches(issue, policy, resolve_assignees(policy, run)):
        reconciled["phase"] = "paused"
    elif isinstance(current, dict):
        reconciled["issue"] = issue
    return reconciled


def _run_directory(workspace, run_id):
    if not run_id or Path(run_id).name != run_id:
        raise ValueError("run_id must be a single path component")
    run_dir = Path(workspace) / ".dark-factory" / "runs" / run_id
    run_dir.mkdir(parents=True, exist_ok=True)
    return run_dir


def build_phase_prompt(workspace, phase, issue, contract_name):
    run_dir = _run_directory(workspace, issue["run_id"])
    contract_path = ROOT / "contracts" / f"{contract_name}.md"
    prompt_path = run_dir / f"{phase}.prompt.md"
    prompt_path.write_text(
        f"{contract_path.read_text().rstrip()}\n\n"
        f"# Selected issue\n\n"
        f"Issue #{issue['number']}: {issue.get('title', '')}\n\n"
        f"```json\n{json.dumps(issue, indent=2, sort_keys=True)}\n```\n"
    )
    return prompt_path


def run_provider(workspace, provider, prompt_file, run_id, *, max_turns):
    try:
        command = list(PROVIDERS[provider])
    except KeyError as error:
        raise ValueError(f"unknown provider: {provider}") from error

    run_dir = _run_directory(workspace, run_id)
    stdout_path = run_dir / "stdout.txt"
    stderr_path = run_dir / "stderr.txt"
    result_path = run_dir / "result.json"
    handoff_path = run_dir / "handoff.md"
    prompt = Path(prompt_file).read_text()
    try:
        completed = subprocess.run(
            command,
            cwd=Path(workspace),
            input=prompt,
            text=True,
            capture_output=True,
            check=False,
        )
        returncode = completed.returncode
        stdout = completed.stdout
        stderr = completed.stderr
    except OSError as error:
        returncode = 127
        stdout = ""
        stderr = str(error)

    capacity_markers = ("capacity", "quota", "rate limit", "usage limit")
    if returncode == 0:
        status = "success"
    elif any(marker in stderr.lower() for marker in capacity_markers):
        status = "capacity_exhausted"
    else:
        status = "failed"

    stdout_path.write_text(stdout)
    stderr_path.write_text(stderr)
    handoff_path.write_text(stdout)
    result_path.write_text(json.dumps({
        "command": command,
        "max_turns": max_turns,
        "provider": provider,
        "returncode": returncode,
        "status": status,
    }, indent=2, sort_keys=True) + "\n")
    return AttemptResult(
        status,
        returncode,
        run_dir,
        stdout_path,
        stderr_path,
        result_path,
        handoff_path,
    )


class StateStore:
    def __init__(self, root):
        self.path = Path(root) / ".dark-factory" / "controller.json"

    def load(self):
        try:
            saved = json.loads(self.path.read_text())
        except FileNotFoundError:
            saved = {}
        return copy.deepcopy(DEFAULT_STATE) | saved

    def save(self, state, force_requested=None):
        self.path.parent.mkdir(parents=True, exist_ok=True)
        lock_path = self.path.parent / ".state.lock"
        descriptor = os.open(lock_path, os.O_CREAT | os.O_RDWR, 0o600)
        temporary_path = None
        try:
            fcntl.flock(descriptor, fcntl.LOCK_EX)
            state = copy.deepcopy(DEFAULT_STATE) | copy.deepcopy(state)
            if force_requested is not None:
                state["requested"] = force_requested
            try:
                current = json.loads(self.path.read_text())
            except (FileNotFoundError, json.JSONDecodeError, OSError):
                current = {}
            if force_requested is None and isinstance(current, dict) and current.get("requested") == "stop":
                state["requested"] = "stop"
            with tempfile.NamedTemporaryFile(
                mode="w",
                dir=self.path.parent,
                prefix=f".{self.path.name}.",
                delete=False,
            ) as temporary:
                temporary_path = Path(temporary.name)
                json.dump(state, temporary, sort_keys=True)
                temporary.write("\n")
                temporary.flush()
                os.fsync(temporary.fileno())
            temporary_path.replace(self.path)
            temporary_path = None
        finally:
            if temporary_path is not None:
                temporary_path.unlink(missing_ok=True)
            fcntl.flock(descriptor, fcntl.LOCK_UN)
            os.close(descriptor)


class ControllerLock:
    def __init__(self, root):
        self.path = Path(root) / ".dark-factory" / "controller.lock"
        self.record = None
        self.descriptor = None

    def __enter__(self):
        return self.acquire()

    def __exit__(self, *unused):
        self.release()

    def acquire(self):
        self.path.parent.mkdir(parents=True, exist_ok=True)
        while True:
            descriptor, temporary_name = tempfile.mkstemp(
                dir=self.path.parent,
                prefix=f".{self.path.name}.{os.getpid()}.",
            )
            temporary_path = Path(temporary_name)
            published = False
            try:
                fcntl.flock(descriptor, fcntl.LOCK_EX)
                record = {
                    "pid": os.getpid(),
                    "started_at": dt.datetime.now(dt.timezone.utc).isoformat(),
                }
                self._write_all(descriptor, (json.dumps(record) + "\n").encode())
                os.fsync(descriptor)
                os.link(temporary_path, self.path)
                published = True
                self.record = record
                self.descriptor = descriptor
                temporary_path.unlink()
                return self
            except FileExistsError:
                self._reclaim_stale_lock()
            finally:
                if not published:
                    fcntl.flock(descriptor, fcntl.LOCK_UN)
                    os.close(descriptor)
                    temporary_path.unlink(missing_ok=True)

    def release(self):
        if self.record is None:
            return
        try:
            if self._matches_path(self.descriptor):
                try:
                    record = json.loads(self.path.read_text())
                except (FileNotFoundError, json.JSONDecodeError):
                    record = None
                if record == self.record:
                    self.path.unlink(missing_ok=True)
        finally:
            fcntl.flock(self.descriptor, fcntl.LOCK_UN)
            os.close(self.descriptor)
            self.descriptor = None
            self.record = None

    def _reclaim_stale_lock(self):
        try:
            descriptor = os.open(self.path, os.O_RDONLY)
        except FileNotFoundError:
            return
        try:
            record = self._read_record(descriptor)
            if not self._valid_record(record):
                raise RuntimeError("dark-factory controller lock is malformed")
            if self._pid_is_live(record["pid"]):
                raise RuntimeError("dark-factory controller is already running")
            try:
                fcntl.flock(descriptor, fcntl.LOCK_EX | fcntl.LOCK_NB)
            except BlockingIOError as error:
                raise RuntimeError("dark-factory controller is already running") from error
            if not self._matches_path(descriptor):
                return
            record = self._read_record(descriptor)
            if not self._valid_record(record):
                raise RuntimeError("dark-factory controller lock is malformed")
            if self._pid_is_live(record["pid"]):
                raise RuntimeError("dark-factory controller is already running")
            self.path.unlink(missing_ok=True)
        finally:
            fcntl.flock(descriptor, fcntl.LOCK_UN)
            os.close(descriptor)

    def _matches_path(self, descriptor):
        try:
            path_status = self.path.stat()
        except FileNotFoundError:
            return False
        descriptor_status = os.fstat(descriptor)
        return (path_status.st_dev, path_status.st_ino) == (
            descriptor_status.st_dev,
            descriptor_status.st_ino,
        )

    @staticmethod
    def _write_all(descriptor, contents):
        while contents:
            written = os.write(descriptor, contents)
            if written <= 0:
                raise OSError("could not write controller lock record")
            contents = contents[written:]

    @staticmethod
    def _read_record(descriptor):
        os.lseek(descriptor, 0, os.SEEK_SET)
        try:
            record = json.loads(os.read(descriptor, 65536).decode())
        except (UnicodeDecodeError, json.JSONDecodeError):
            return None
        return record if isinstance(record, dict) else None

    @staticmethod
    def _valid_record(record):
        return (
            isinstance(record, dict)
            and isinstance(record.get("pid"), int)
            and not isinstance(record["pid"], bool)
            and record["pid"] > 0
            and isinstance(record.get("started_at"), str)
            and bool(record["started_at"].strip())
        )

    @staticmethod
    def _pid_is_live(pid):
        try:
            os.kill(pid, 0)
        except ProcessLookupError:
            return False
        except PermissionError:
            return True
        return True


def main(argv=None):
    arguments = list(sys.argv[1:] if argv is None else argv)
    if not arguments:
        return 0
    if arguments[0] != "provider":
        raise ValueError(f"unknown subcommand: {arguments[0]}")
    if len(arguments) not in (5, 7):
        raise ValueError(
            "usage: dark-factory provider WORKSPACE PROVIDER PROMPT RUN_ID "
            "[--max-turns N]"
        )
    max_turns = 40
    if len(arguments) == 7:
        if arguments[5] != "--max-turns":
            raise ValueError("expected --max-turns")
        max_turns = int(arguments[6])
    result = run_provider(
        arguments[1],
        arguments[2],
        arguments[3],
        arguments[4],
        max_turns=max_turns,
    )
    return result.returncode


if __name__ == "__main__":
    sys.exit(main())
