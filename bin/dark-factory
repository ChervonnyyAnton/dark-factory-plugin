#!/usr/bin/env python3
import argparse
import copy
import datetime as dt
import fcntl
import json
import os
import re
import subprocess
import sys
import tempfile
import time
import uuid
from collections import namedtuple
from pathlib import Path
from urllib.parse import urlparse


ROOT = Path(__file__).resolve().parents[1]
PROVIDERS = {
    "claude": ("claude", "-p", "--dangerously-skip-permissions"),
    "codex": (
        "codex",
        "exec",
        "--dangerously-bypass-approvals-and-sandbox",
        "-",
    ),
}
AttemptResult = namedtuple(
    "AttemptResult",
    "status returncode run_dir stdout_path stderr_path result_path handoff_path",
)

DEFAULT_STATE = {
    "version": 1,
    "requested": "stopped",
    "phase": "idle",
    "project": None,
    "issue": None,
    "focus": None,
    "pr": None,
    "pr_url": None,
    "pr_title": None,
    "pr_body": None,
    "branch": None,
    "head_sha": None,
    "ci_checks": None,
    "failed_check": None,
    "merge_error": None,
    "handoff_reason": None,
    "release_note": None,
    "waiting_for_capacity": False,
    "testing": None,
    "self_review": None,
    "security_review": None,
    "attempts": {},
    "cooldowns": {},
    "next_wake_at": None,
    "updated_at": None,
}

# Delivery phase order and the role contract each phase runs. `ready_for_pr`
# and `repairing` are handled by dedicated dispatch branches (they also talk
# to GitHub) rather than the generic execution/judgement helpers below.
PHASE_CONTRACTS = {
    "planning": "planner",
    "implementing": "implementer",
    "testing": "tester",
    "self_review": "reviewer",
    "security_review": "security-reviewer",
    "ready_for_pr": "pr-author",
    "repairing": "repairer",
    "releaser": "releaser",
}

PHASE_PROVIDER_ROLE = {
    "planning": "implement",
    "implementing": "implement",
    "testing": "review",
    "self_review": "review",
    "security_review": "review",
    "ready_for_pr": "implement",
    "repairing": "implement",
    "releaser": "review",
}

# Phase reached after a *passing* attempt. `ready_for_pr` is excluded: a
# passing pr-author attempt stays in `ready_for_pr` until `open_pr` records a
# pull request and advances to `ci_wait`. `repairing` is excluded from
# jumping straight back to `ci_wait`: it must re-earn a fresh
# testing/self_review/security_review pass (its recorded evidence is stale
# once new commits land), so it re-enters the judgement chain at `testing`
# and only reaches `ci_wait` again via `ready_for_pr`'s existing-PR reuse.
_NEXT_PHASE = {
    "planning": "implementing",
    "implementing": "testing",
    "testing": "self_review",
    "self_review": "security_review",
    "security_review": "ready_for_pr",
    "repairing": "testing",
}

# Judgement phases require the role contract's structured pass/fail/blocked
# verdict; a failure (or an unparseable verdict) loops back to `implementing`
# within `limits.max_check_repairs`, then hands off.
_JUDGEMENT_PHASES = ("testing", "self_review", "security_review")

_TERMINAL_PHASES = ("merged", "handoff", "idle", "paused")


def load_policy(root):
    return json.loads((Path(root) / ".dark-factory" / "policy.json").read_text())


def resolve_assignees(policy, run):
    raw = policy.get("queue", {}).get("assignees", [])
    me_login = None
    resolved = []
    for assignee in raw:
        if assignee == "@me":
            if me_login is None:
                result = run(["gh", "api", "user", "-q", ".login"])
                me_login = result.stdout.strip()
            resolved.append(me_login)
        else:
            resolved.append(assignee)
    return resolved


def issue_matches(issue, policy, assignees):
    queue = policy.get("queue", {})
    labels = queue.get("labels", [])
    match_mode = queue.get("match", "any")

    issue_logins = {a.get("login") for a in issue.get("assignees", [])}
    issue_labels = {label.get("name") for label in issue.get("labels", [])}

    assignee_match = bool(issue_logins & set(assignees))
    label_match = bool(issue_labels & set(labels))

    if match_mode == "all":
        return assignee_match and label_match
    return assignee_match or label_match


def _repository_from_origin(run):
    remote = run(["git", "remote", "get-url", "origin"]).stdout.strip()
    if "://" in remote:
        repository = urlparse(remote).path.lstrip("/")
    else:
        repository = remote.rsplit(":", 1)[-1]
    return repository.rstrip("/").removesuffix(".git")


def list_matching_issues(run, policy):
    repositories = policy.get("repositories") or [_repository_from_origin(run)]
    assignees = resolve_assignees(policy, run)
    matches = []
    fields = "number,title,url,createdAt,assignees,labels"
    for repository in repositories:
        result = run([
            "gh", "issue", "list",
            "--repo", repository,
            "--state", "open",
            "--json", fields,
        ])
        for issue in json.loads(result.stdout):
            issue = dict(issue, repository=repository)
            if issue_matches(issue, policy, assignees):
                matches.append(issue)
    return matches


def select_issue(issues):
    return min(
        issues,
        key=lambda issue: (
            issue["createdAt"],
            issue["repository"],
            issue["number"],
        ),
        default=None,
    )


_ISSUE_FIELDS = "number,title,url,createdAt,assignees,labels,state,body"


def resolve_issue(run, policy, number):
    repositories = policy.get("repositories") or [_repository_from_origin(run)]
    found = []
    for repository in repositories:
        result = run([
            "gh", "issue", "view", str(number),
            "--repo", repository,
            "--json", _ISSUE_FIELDS,
        ])
        if getattr(result, "returncode", 0) != 0 or not (result.stdout or "").strip():
            continue
        found.append(dict(json.loads(result.stdout), repository=repository))
    if not found:
        raise ValueError(f"issue #{number} not found in policy repositories")
    if len(found) > 1:
        repos = ", ".join(item["repository"] for item in found)
        raise ValueError(f"issue #{number} is ambiguous across repositories: {repos}")
    return found[0]


def _assignee_logins(issue):
    return {a.get("login") for a in issue.get("assignees", []) if a.get("login")}


def select_pinned_issue(run, policy, number):
    issue = resolve_issue(run, policy, number)
    if str(issue.get("state", "")).upper() != "OPEN":
        raise ValueError(f"issue #{number} is not open")
    assignees = set(resolve_assignees(policy, run))
    if not (_assignee_logins(issue) & assignees):
        raise ValueError(f"issue #{number} is not assigned to the policy assignees")
    return issue


_CHILD_RE = re.compile(r"#(\d+)\b")


def discover_epic_child_numbers(run, epic):
    numbers = []
    seen = set()
    repository = epic["repository"]
    owner, name = repository.split("/", 1)
    query = (
        "query($owner:String!,$name:String!,$number:Int!){"
        "repository(owner:$owner,name:$name){issue(number:$number){"
        "trackedIssues(first:100){nodes{number}}}}}"
    )
    result = run([
        "gh", "api", "graphql",
        "-f", f"query={query}",
        "-f", f"owner={owner}",
        "-f", f"name={name}",
        "-F", f"number={epic['number']}",
    ])
    if getattr(result, "returncode", 0) == 0 and (result.stdout or "").strip():
        try:
            nodes = (
                json.loads(result.stdout)
                .get("data", {})
                .get("repository", {})
                .get("issue", {})
                .get("trackedIssues", {})
                .get("nodes", [])
            )
        except json.JSONDecodeError:
            nodes = []
        for node in nodes or []:
            number = node.get("number")
            if isinstance(number, int) and number not in seen:
                seen.add(number)
                numbers.append(number)
    for match in _CHILD_RE.finditer(epic.get("body") or ""):
        number = int(match.group(1))
        if number == epic["number"] or number in seen:
            continue
        seen.add(number)
        numbers.append(number)
    return numbers


def epic_child_eligible(issue, policy, assignees):
    if str(issue.get("state", "")).upper() != "OPEN":
        return False
    logins = _assignee_logins(issue)
    assignee_set = set(assignees)
    if logins and not (logins & assignee_set):
        return False
    labels = policy.get("queue", {}).get("labels") or []
    if labels:
        issue_labels = {label.get("name") for label in issue.get("labels", [])}
        if not (issue_labels & set(labels)):
            return False
    return True


def select_with_focus(run, policy, *, issue=None, epic=None):
    if issue is not None and epic is not None:
        raise ValueError("--issue and --epic are mutually exclusive")
    if issue is not None:
        selected = select_pinned_issue(run, policy, issue)
        return selected, f"pinned issue #{selected['number']}"
    if epic is None:
        selected = select_issue(list_matching_issues(run, policy))
        if selected is None:
            return None, "no eligible issue"
        return selected, f"queue selected issue #{selected['number']}"

    epic_issue = resolve_issue(run, policy, epic)
    assignees = resolve_assignees(policy, run)
    if str(epic_issue.get("state", "")).upper() != "OPEN":
        return None, f"epic #{epic} is already closed; nothing to deliver"
    if not (_assignee_logins(epic_issue) & set(assignees)):
        raise ValueError(f"epic #{epic} is not assigned to the policy assignees")

    resolved = []
    unresolved = []
    for number in discover_epic_child_numbers(run, epic_issue):
        try:
            resolved.append(resolve_issue(run, policy, number))
        except ValueError:
            unresolved.append(number)

    eligible = [
        child for child in resolved
        if epic_child_eligible(child, policy, assignees)
    ]
    if eligible:
        selected = select_issue(eligible)
        summary = f"epic #{epic} child #{selected['number']}"
        if unresolved:
            summary += f"; unresolved child refs ignored: {unresolved}"
        return selected, summary

    open_resolved = [
        child for child in resolved
        if str(child.get("state", "")).upper() == "OPEN"
    ]
    if open_resolved:
        raise ValueError(
            f"epic #{epic} has open children that are not eligible under policy"
        )

    selected = dict(epic_issue, selection_intent="epic_closure")
    summary = f"epic #{epic} closure"
    if unresolved:
        summary += f"; unresolved child refs ignored: {unresolved}"
    return selected, summary


def reconcile(state, run, policy):
    reconciled = copy.deepcopy(state)
    current = reconciled["issue"]
    if isinstance(current, dict):
        repository = current["repository"]
        number = current["number"]
    else:
        repository = reconciled["repository"]
        number = current
    fields = "number,title,url,createdAt,assignees,labels"
    result = run([
        "gh", "issue", "view", str(number),
        "--repo", repository,
        "--json", fields,
    ])
    issue = dict(json.loads(result.stdout), repository=repository)
    if isinstance(current, dict) and current.get("run_id"):
        issue["run_id"] = current["run_id"]
    if isinstance(current, dict) and current.get("selection_intent"):
        issue["selection_intent"] = current["selection_intent"]
    if not issue_matches(issue, policy, resolve_assignees(policy, run)):
        reconciled["phase"] = "paused"
    elif isinstance(current, dict):
        reconciled["issue"] = issue
    return reconciled


def _run_directory(workspace, run_id):
    if not run_id or Path(run_id).name != run_id:
        raise ValueError("run_id must be a single path component")
    run_dir = Path(workspace) / ".dark-factory" / "runs" / run_id
    run_dir.mkdir(parents=True, exist_ok=True)
    return run_dir


def _review_phase_output(record):
    if not isinstance(record, dict):
        return ""
    run_dir = record.get("run_dir")
    if not run_dir:
        return ""
    stdout_path = Path(run_dir) / "stdout.txt"
    return stdout_path.read_text().rstrip() if stdout_path.is_file() else ""


def _repair_context_block(state):
    """Summarize the named CI failure and any recorded review evidence."""
    parts = ["# Repair context\n"]
    failed_check = state.get("failed_check")
    if failed_check:
        parts.append(f"Failed CI check: `{failed_check}`\n")
    pr = state.get("pr")
    if pr:
        parts.append(f"Pull request: #{pr}\n")
    evidence = []
    for phase in ("testing", "self_review", "security_review"):
        record = state.get(phase)
        if not record:
            continue
        section = [
            f"## {phase}\n\n"
            f"```json\n{json.dumps(record, indent=2, sort_keys=True)}\n```\n",
        ]
        output = _review_phase_output(record)
        if output:
            section.append(f"\nProvider output:\n\n```\n{output}\n```\n")
        evidence.append("".join(section))
    if evidence:
        parts.append("\n## Review evidence\n\n")
        parts.extend(evidence)
    return "\n".join(parts) if len(parts) > 1 else ""


def build_phase_prompt(workspace, phase, issue, contract_name, *, state=None):
    run_dir = _run_directory(workspace, issue["run_id"])
    contract_path = ROOT / "contracts" / f"{contract_name}.md"
    prompt_path = run_dir / f"{phase}.prompt.md"
    text = (
        f"{contract_path.read_text().rstrip()}\n\n"
        f"# Selected issue\n\n"
        f"Issue #{issue['number']}: {issue.get('title', '')}\n\n"
        f"```json\n{json.dumps(issue, indent=2, sort_keys=True)}\n```\n"
    )
    if issue.get("selection_intent") == "epic_closure":
        closure_contract = (ROOT / "contracts" / "epic-closure.md").read_text().rstrip()
        text = f"{text.rstrip()}\n\n{closure_contract}\n"
    if phase == "repairing" and state:
        context = _repair_context_block(state)
        if context:
            text = f"{text.rstrip()}\n\n{context}\n"
    elif phase == "releaser" and state:
        text = (
            f"{text.rstrip()}\n\n# Deterministic delivery state\n\n"
            "Author the human-facing handoff note from this state. Do not alter "
            "or reinterpret its merge decision.\n\n"
            f"```json\n{json.dumps(state, indent=2, sort_keys=True)}\n```\n"
        )
    prompt_path.write_text(text)
    return prompt_path


def run_provider(workspace, provider, prompt_file, run_id, *, max_turns):
    try:
        command = list(PROVIDERS[provider])
    except KeyError as error:
        raise ValueError(f"unknown provider: {provider}") from error

    run_dir = _run_directory(workspace, run_id)
    stdout_path = run_dir / "stdout.txt"
    stderr_path = run_dir / "stderr.txt"
    result_path = run_dir / "result.json"
    handoff_path = run_dir / "handoff.md"
    prompt = Path(prompt_file).read_text()
    try:
        completed = subprocess.run(
            command,
            cwd=Path(workspace),
            input=prompt,
            text=True,
            capture_output=True,
            check=False,
        )
        returncode = completed.returncode
        stdout = completed.stdout
        stderr = completed.stderr
    except OSError as error:
        returncode = 127
        stdout = ""
        stderr = str(error)

    capacity_markers = ("capacity", "quota", "rate limit", "usage limit")
    if returncode == 0:
        status = "success"
    elif any(marker in stderr.lower() for marker in capacity_markers):
        status = "capacity_exhausted"
    else:
        status = "failed"

    stdout_path.write_text(stdout)
    stderr_path.write_text(stderr)
    handoff_path.write_text(stdout)
    result_path.write_text(json.dumps({
        "command": command,
        "max_turns": max_turns,
        "provider": provider,
        "returncode": returncode,
        "status": status,
    }, indent=2, sort_keys=True) + "\n")
    return AttemptResult(
        status,
        returncode,
        run_dir,
        stdout_path,
        stderr_path,
        result_path,
        handoff_path,
    )


def _json_result(result):
    output = result.stdout if hasattr(result, "stdout") else result
    if isinstance(output, bytes):
        output = output.decode()
    return json.loads(output)


def _select_provider(policy, role):
    providers = policy.get("providers", {}).get(role) or ["claude"]
    return providers[0]


def _extract_status(text):
    """Return the last well-formed `{"status": "pass"|"fail"|"blocked", ...}`
    object found in provider output, including pretty-printed JSON surrounded
    by prose."""
    status = None
    decoder = json.JSONDecoder()
    for match in re.finditer(r"\{", text):
        try:
            payload, _ = decoder.raw_decode(text, match.start())
        except json.JSONDecodeError:
            continue
        if isinstance(payload, dict) and payload.get("status") in ("pass", "fail", "blocked"):
            status = payload["status"]
    return status


_PR_SECTION_RE = re.compile(
    r"^#{1,3}\s*(Commit message|Pull request title|Pull request body)\s*$",
    re.IGNORECASE | re.MULTILINE,
)


def _parse_pr_title_and_body(text):
    """Parse pr-author output. Labelled sections separate the commit message
    from the pull request title/body; legacy output without a commit-message
    section keeps the first line as the title."""
    text = text.strip()
    if not text:
        return "", ""

    matches = list(_PR_SECTION_RE.finditer(text))
    if matches:
        sections = {}
        for index, match in enumerate(matches):
            key = match.group(1).lower()
            start = match.end()
            end = matches[index + 1].start() if index + 1 < len(matches) else len(text)
            sections[key] = text[start:end].strip()
        return (
            sections.get("pull request title", ""),
            sections.get("pull request body", ""),
        )

    lines = text.splitlines()
    title = lines[0].lstrip("#").strip()
    body = "\n".join(lines[1:]).strip()
    return title, body


def _ensure_closes(body, number):
    marker = f"Closes #{number}"
    body = (body or "").strip()
    if marker in body:
        return body
    return marker if not body else f"{body}\n\n{marker}"


def _run_phase_provider(workspace, state, policy, phase, run_provider_fn):
    issue = state["issue"]
    attempts = state.get("attempts", {})
    prompt_path = build_phase_prompt(
        workspace, phase, issue, PHASE_CONTRACTS[phase], state=state,
    )
    provider = _select_provider(policy, PHASE_PROVIDER_ROLE[phase])
    run_id = f"{issue['run_id']}-{phase}-{attempts.get(phase, 0)}"
    max_turns = policy.get("limits", {}).get("max_turns", 40)
    return run_provider_fn(workspace, provider, prompt_path, run_id, max_turns=max_turns)


def _record_repair_or_handoff(state, phase, policy, reason):
    attempts = state.setdefault("attempts", {})
    attempts[phase] = int(attempts.get(phase, 0)) + 1
    limit = policy.get("limits", {}).get("max_check_repairs", 5)
    if attempts[phase] >= limit:
        state["phase"] = "handoff"
        state["handoff_reason"] = f"{reason} after {attempts[phase]} attempts"
    else:
        state["phase"] = "implementing"
    return state


def _advance_execution_phase(workspace, state, policy, phase, run_provider_fn):
    """Run a non-judgement role contract (planner/implementer/pr-author/
    repairer). Success advances to the next phase (or, for `ready_for_pr`,
    records the drafted PR title/body for `open_pr` to consume). Failure
    retries within `limits.max_check_repairs`, then hands off."""
    state = copy.deepcopy(DEFAULT_STATE) | copy.deepcopy(state)
    attempt = _run_phase_provider(workspace, state, policy, phase, run_provider_fn)
    if attempt.status == "success":
        if phase == "ready_for_pr":
            title, body = _parse_pr_title_and_body(attempt.stdout_path.read_text())
            state["pr_title"] = title
            state["pr_body"] = body
            return state
        state["phase"] = _NEXT_PHASE[phase]
        return state
    if attempt.status == "capacity_exhausted":
        state["waiting_for_capacity"] = True
        return state
    return _record_repair_or_handoff(state, phase, policy, f"{phase} failed")


def _advance_judgement_phase(workspace, state, policy, phase, run_provider_fn):
    """Run a reviewer/tester/security-reviewer contract and act on its
    structured verdict. `pass` advances; `fail`/`blocked`/unparseable output
    loops back to `implementing` within budget, then hands off."""
    state = copy.deepcopy(DEFAULT_STATE) | copy.deepcopy(state)
    attempt = _run_phase_provider(workspace, state, policy, phase, run_provider_fn)
    if attempt.status == "capacity_exhausted":
        state["waiting_for_capacity"] = True
        return state
    verdict = _extract_status(attempt.stdout_path.read_text()) if attempt.status == "success" else None
    state[phase] = {"status": verdict, "provider_status": attempt.status, "run_dir": str(attempt.run_dir)}
    if verdict == "pass":
        state["phase"] = _NEXT_PHASE[phase]
        return state
    return _record_repair_or_handoff(state, phase, policy, f"{phase} did not pass")


def _author_release_note(workspace, state, policy, run_provider_fn):
    """Invoke the releaser for prose only; deterministic state remains authoritative."""
    attempt = _run_phase_provider(
        workspace, state, policy, "releaser", run_provider_fn,
    )
    state["release_note"] = {
        "provider_status": attempt.status,
        "run_dir": str(attempt.run_dir),
        "path": str(attempt.handoff_path),
    }
    return state


def push_branch(run, workspace, branch):
    """Push the worktree's local commits to `origin/<branch>`. Every
    provider role contract forbids pushing, so the supervisor performs this
    step itself, through the same injectable `run` used for GitHub calls,
    before `open_pr` ever asks GitHub about the branch."""
    result = run(["git", "-C", str(workspace), "push", "-u", "origin", f"HEAD:{branch}"])
    returncode = getattr(result, "returncode", 0)
    if returncode != 0:
        raise RuntimeError(getattr(result, "stderr", "") or "git push failed")
    return result


def open_pr(run, state, workspace):
    """Push the branch's commits to origin, then create (or reuse) the pull
    request for the current issue/branch, ensuring the body records
    `Closes #N`, and advance to `ci_wait`."""
    state = copy.deepcopy(DEFAULT_STATE) | copy.deepcopy(state)
    issue = state["issue"]
    repository = issue["repository"]
    branch = state.get("branch")
    if not branch:
        raise ValueError("state must contain a factory branch")
    push_branch(run, workspace, branch)
    number = issue["number"]
    fields = "number,url,state,headRefOid,headRefName"

    if state.get("pr"):
        pr = _json_result(run(["gh", "pr", "view", str(state["pr"]), "--repo", repository, "--json", fields]))
        if isinstance(pr, dict) and pr.get("state") == "OPEN" and pr.get("number") == state["pr"]:
            state.update(
                pr_url=pr.get("url", state.get("pr_url")),
                head_sha=pr.get("headRefOid", state.get("head_sha")),
                branch=pr.get("headRefName", branch),
                phase="ci_wait",
            )
            return state

    existing = _json_result(run(["gh", "pr", "list", "--repo", repository, "--head", branch, "--state", "open", "--json", fields]))
    if isinstance(existing, list) and existing:
        pr = existing[0]
        state.update(
            pr=pr["number"], pr_url=pr.get("url"), head_sha=pr.get("headRefOid"),
            branch=pr.get("headRefName", branch), phase="ci_wait",
        )
        return state

    title = state.get("pr_title") or f"Issue #{number}: {issue.get('title', '')}".rstrip(": ")
    body = _ensure_closes(state.get("pr_body"), number)
    created = run(["gh", "pr", "create", "--repo", repository, "--head", branch, "--title", title, "--body", body])
    output = created.stdout if hasattr(created, "stdout") else str(created)
    match = re.search(r"/pull/(\d+)", output)
    if not match:
        raise RuntimeError("gh pr create did not return a pull-request URL")
    pr = _json_result(run(["gh", "pr", "view", match.group(1), "--repo", repository, "--json", fields]))
    if not isinstance(pr, dict) or not isinstance(pr.get("number"), int):
        raise RuntimeError("gh pr view returned incomplete pull-request metadata")
    state.update(
        pr=pr["number"], pr_url=pr.get("url"), head_sha=pr.get("headRefOid"),
        branch=pr.get("headRefName", branch), pr_title=title, pr_body=body, phase="ci_wait",
    )
    return state


def _valid_checks(checks):
    return isinstance(checks, list) and bool(checks) and all(
        isinstance(check, dict)
        and isinstance(check.get("name"), str) and check["name"]
        and isinstance(check.get("bucket"), str)
        for check in checks
    )


def _checks_green(checks):
    return all(check["bucket"] in ("pass", "skipping") for check in checks)


def _first_failed_check(checks):
    return next(
        (check["name"] for check in checks if check["bucket"] not in ("pass", "skipping", "pending")),
        None,
    )


def repair_or_handoff(state, failed_check, policy):
    """Record a failing check attempt; hand off once
    `limits.max_check_repairs` (default 5) is reached, otherwise repair."""
    state = copy.deepcopy(DEFAULT_STATE) | copy.deepcopy(state)
    key = f"ci:{failed_check}"
    attempts = state.setdefault("attempts", {})
    attempts[key] = int(attempts.get(key, 0)) + 1
    limit = policy.get("limits", {}).get("max_check_repairs", 5)
    state["failed_check"] = failed_check
    if attempts[key] >= limit:
        state["phase"] = "handoff"
        state["handoff_reason"] = f"check '{failed_check}' failed {attempts[key]} times"
    else:
        state["phase"] = "repairing"
    return state


def watch_ci(run, state, policy):
    """Poll PR checks once. Green leaves `ci_wait` with `ci_checks: green`
    for the caller to make the merge/handoff decision; a failing check goes
    through `repair_or_handoff`; pending/malformed checks stay in `ci_wait`."""
    state = copy.deepcopy(DEFAULT_STATE) | copy.deepcopy(state)
    state["phase"] = "ci_wait"
    issue = state["issue"]
    repository = issue["repository"]
    if state.get("pr") is None:
        return state
    result = run(["gh", "pr", "checks", str(state["pr"]), "--repo", repository, "--json", "name,state,bucket"])
    try:
        checks = _json_result(result)
    except (TypeError, ValueError, json.JSONDecodeError):
        return repair_or_handoff(state, "malformed-ci", policy)
    if not _valid_checks(checks):
        return repair_or_handoff(state, "malformed-ci", policy)
    if _checks_green(checks):
        state["ci_checks"] = "green"
        return state
    failed = _first_failed_check(checks)
    if failed is None:
        state["ci_checks"] = "pending"
        return state
    return repair_or_handoff(state, failed, policy)


def _repository_parts(repository):
    owner, separator, name = str(repository).partition("/")
    if not separator or not owner or not name:
        raise ValueError("repository must be owner/name")
    return owner, name


def _review_threads(run, repository, number):
    """Query the PR's `reviewDecision` and paginated `reviewThreads` over
    GraphQL, returning `(decision, unresolved_count)`. Fails closed to
    `(None, 1)` on GraphQL errors, missing/malformed data, or an
    incomplete/further-paginated `pageInfo`, so a caller that requires
    `unresolved == 0` never treats an unreadable or partially-fetched
    thread list as clean."""
    owner, name = _repository_parts(repository)
    query = (
        "query($owner:String!, $name:String!, $number:Int!) { repository(owner:$owner,name:$name) "
        "{ pullRequest(number:$number) { reviewDecision reviewThreads(first:100) "
        "{ nodes { isResolved } pageInfo { hasNextPage } } } } }"
    )
    try:
        result = _json_result(run([
            "gh", "api", "graphql", "-f", f"query={query}", "-F", f"owner={owner}",
            "-F", f"name={name}", "-F", f"number={number}",
        ]))
    except (ValueError, TypeError, json.JSONDecodeError):
        return None, 1
    if not isinstance(result, dict) or result.get("errors"):
        return None, 1
    data = result.get("data")
    repository_data = data.get("repository") if isinstance(data, dict) else None
    pull_request = repository_data.get("pullRequest") if isinstance(repository_data, dict) else None
    if not isinstance(pull_request, dict):
        return None, 1
    threads = pull_request.get("reviewThreads")
    if not isinstance(threads, dict) or not isinstance(threads.get("nodes"), list):
        return None, 1
    nodes = threads["nodes"]
    if any(
        not isinstance(node, dict) or not isinstance(node.get("isResolved"), bool)
        for node in nodes
    ):
        return None, 1
    page_info = threads.get("pageInfo")
    if not isinstance(page_info, dict) or not isinstance(page_info.get("hasNextPage"), bool):
        return None, 1
    unresolved = sum(1 for node in nodes if not node["isResolved"])
    if page_info["hasNextPage"]:
        # A second page of threads exists but is not fetched; fail closed
        # rather than assume the unseen threads are resolved.
        unresolved += 1
    return pull_request.get("reviewDecision"), unresolved


def merge_ready(run, state):
    """True only when every strict auto-merge gate is satisfied against
    fresh GitHub evidence: recorded native verification (`testing`) and
    self/security review pass, an open PR matching the controller-recorded
    head SHA, an explicit `APPROVED` review decision (a `null`/missing
    decision is never treated as a pass), zero unresolved review threads,
    and green required checks."""
    state = copy.deepcopy(DEFAULT_STATE) | copy.deepcopy(state)
    if (state.get("testing") or {}).get("status") != "pass":
        return False
    if (state.get("self_review") or {}).get("status") != "pass":
        return False
    if (state.get("security_review") or {}).get("status") != "pass":
        return False
    issue = state.get("issue") or {}
    repository = issue.get("repository")
    if (
        not repository
        or not isinstance(state.get("pr"), int) or isinstance(state["pr"], bool) or state["pr"] <= 0
        or not isinstance(state.get("pr_url"), str) or not state["pr_url"]
        or not isinstance(state.get("head_sha"), str) or not state["head_sha"]
    ):
        return False
    try:
        pr = _json_result(run([
            "gh", "pr", "view", str(state["pr"]), "--repo", repository,
            "--json", "number,url,state,headRefOid",
        ]))
        checks = _json_result(run([
            "gh", "pr", "checks", str(state["pr"]), "--repo", repository,
            "--json", "name,state,bucket",
        ]))
        decision, unresolved = _review_threads(run, repository, int(state["pr"]))
    except (KeyError, RuntimeError, ValueError, TypeError, json.JSONDecodeError):
        return False
    if not isinstance(pr, dict):
        return False
    return (
        pr.get("state") == "OPEN"
        and pr.get("number") == state["pr"]
        and pr.get("headRefOid") == state["head_sha"]
        and _valid_checks(checks)
        and _checks_green(checks)
        and decision == "APPROVED"
        and unresolved == 0
    )


def merge_pr(run, state):
    """Merge only when `merge_ready`; never force-push or bypass checks."""
    state = copy.deepcopy(DEFAULT_STATE) | copy.deepcopy(state)
    if not merge_ready(run, state):
        return state
    issue = state["issue"]
    repository = issue["repository"]
    result = run([
        "gh", "pr", "merge", str(state["pr"]), "--repo", repository,
        "--match-head-commit", state["head_sha"], "--squash", "--delete-branch",
    ])
    returncode = getattr(result, "returncode", 0)
    output = getattr(result, "stdout", "") or ""
    if returncode != 0 or any(marker in output.lower() for marker in ("error", "failed", "rejected")):
        state["phase"] = "handoff"
        state["merge_error"] = getattr(result, "stderr", "") or output or "gh pr merge failed"
        return state
    state["phase"] = "merged"
    return state


def close_epic_if_needed(run, state):
    issue = state.get("issue") or {}
    if issue.get("selection_intent") != "epic_closure" or state.get("phase") != "merged":
        return state
    result = run([
        "gh", "issue", "close", str(issue["number"]),
        "--repo", issue["repository"],
        "--comment", "Closed by Dark Factory epic closure after merge.",
    ])
    if getattr(result, "returncode", 0) != 0:
        state["phase"] = "handoff"
        state["handoff_reason"] = "merged but failed to close epic"
        return state
    state["phase"] = "idle"
    state["issue"] = None
    return state


def _focus_dict(issue=None, epic=None):
    if issue is not None:
        return {"issue": issue}
    if epic is not None:
        return {"epic": epic}
    return None


def _select_next_issue(run, policy, focus=None):
    return select_with_focus(run, policy, **(focus or {}))[0]


def _controller_iteration(store, run, *, run_provider_fn=run_provider):
    """Advance persisted delivery state by exactly one step:
    `planning -> implementing -> testing -> self_review -> security_review
    -> ready_for_pr -> ci_wait -> repairing -> merged|handoff|idle`.

    Returns True when the caller should iterate again, False once the
    delivery reaches a terminal phase (`merged`, `handoff`, `idle`) or no
    matching issue remains.
    """
    state = store.load()
    if state.get("requested") == "stop":
        state["phase"] = "stopped"
        store.save(state)
        return False
    workspace = store.path.parent.parent
    policy = load_policy(workspace)

    if state.get("issue") is None:
        selected = _select_next_issue(run, policy, state.get("focus"))
        if selected is None:
            state["phase"] = "idle"
            store.save(state)
            return False
        number = selected["number"]
        selected = dict(selected, run_id=f"issue-{number}-{uuid.uuid4().hex[:8]}")
        state.update(
            issue=selected,
            branch=f"dark-factory/issue-{number}",
            phase="planning",
            pr=None, pr_url=None, pr_title=None, pr_body=None, head_sha=None,
            testing=None, self_review=None, security_review=None,
            attempts={},
        )
        store.save(state)
        return True

    phase = state.get("phase")

    if phase in ("planning", "implementing", "repairing"):
        state = _advance_execution_phase(workspace, state, policy, phase, run_provider_fn)
    elif phase in _JUDGEMENT_PHASES:
        state = _advance_judgement_phase(workspace, state, policy, phase, run_provider_fn)
    elif phase == "ready_for_pr":
        if not state.get("pr_body"):
            state = _advance_execution_phase(workspace, state, policy, phase, run_provider_fn)
        if state.get("phase") == "ready_for_pr" and state.get("pr_body"):
            state = open_pr(run, state, workspace)
    elif phase == "ci_wait":
        state = watch_ci(run, state, policy)
        if state.get("phase") == "ci_wait" and state.get("ci_checks") == "green":
            if policy.get("merge", {}).get("mode", "manual") == "auto":
                # Re-validate the issue against the live policy queue filters
                # immediately before merging: labels/assignees may have
                # drifted since the issue was selected or last reconciled.
                state = reconcile(state, run, policy)
                if state.get("phase") == "paused":
                    pass
                elif merge_ready(run, state):
                    state = merge_pr(run, state)
                else:
                    state["phase"] = "handoff"
                    state["handoff_reason"] = "auto merge gate not satisfied"
            else:
                state["phase"] = "handoff"
                state["handoff_reason"] = "checks green; manual merge mode awaits human merge"
    elif phase != "merged":
        store.save(state)
        return False

    if state.get("phase") in ("handoff", "merged") and state.get("phase") != phase:
        state = _author_release_note(workspace, state, policy, run_provider_fn)
    if state.get("phase") == "merged":
        state = close_epic_if_needed(run, state)
        focus = state.get("focus") or {}
        if state.get("phase") == "merged" and focus:
            state.update(
                phase="idle",
                issue=None,
                pr=None, pr_url=None, pr_title=None, pr_body=None, head_sha=None,
                testing=None, self_review=None, security_review=None,
                attempts={},
            )
            store.save(state)
            return focus.get("epic") is not None
    store.save(state)
    return state.get("phase") not in _TERMINAL_PHASES


class StateStore:
    def __init__(self, root):
        self.path = Path(root) / ".dark-factory" / "controller.json"

    def load(self):
        try:
            saved = json.loads(self.path.read_text())
        except FileNotFoundError:
            saved = {}
        return copy.deepcopy(DEFAULT_STATE) | saved

    def save(self, state, force_requested=None):
        self.path.parent.mkdir(parents=True, exist_ok=True)
        lock_path = self.path.parent / ".state.lock"
        descriptor = os.open(lock_path, os.O_CREAT | os.O_RDWR, 0o600)
        temporary_path = None
        try:
            fcntl.flock(descriptor, fcntl.LOCK_EX)
            state = copy.deepcopy(DEFAULT_STATE) | copy.deepcopy(state)
            if force_requested is not None:
                state["requested"] = force_requested
            try:
                current = json.loads(self.path.read_text())
            except (FileNotFoundError, json.JSONDecodeError, OSError):
                current = {}
            if force_requested is None and isinstance(current, dict) and current.get("requested") == "stop":
                state["requested"] = "stop"
            with tempfile.NamedTemporaryFile(
                mode="w",
                dir=self.path.parent,
                prefix=f".{self.path.name}.",
                delete=False,
            ) as temporary:
                temporary_path = Path(temporary.name)
                json.dump(state, temporary, sort_keys=True)
                temporary.write("\n")
                temporary.flush()
                os.fsync(temporary.fileno())
            temporary_path.replace(self.path)
            temporary_path = None
        finally:
            if temporary_path is not None:
                temporary_path.unlink(missing_ok=True)
            fcntl.flock(descriptor, fcntl.LOCK_UN)
            os.close(descriptor)


class ControllerLock:
    def __init__(self, root):
        self.path = Path(root) / ".dark-factory" / "controller.lock"
        self.record = None
        self.descriptor = None

    def __enter__(self):
        return self.acquire()

    def __exit__(self, *unused):
        self.release()

    def acquire(self):
        self.path.parent.mkdir(parents=True, exist_ok=True)
        while True:
            descriptor, temporary_name = tempfile.mkstemp(
                dir=self.path.parent,
                prefix=f".{self.path.name}.{os.getpid()}.",
            )
            temporary_path = Path(temporary_name)
            published = False
            try:
                fcntl.flock(descriptor, fcntl.LOCK_EX)
                record = {
                    "pid": os.getpid(),
                    "started_at": dt.datetime.now(dt.timezone.utc).isoformat(),
                }
                self._write_all(descriptor, (json.dumps(record) + "\n").encode())
                os.fsync(descriptor)
                os.link(temporary_path, self.path)
                published = True
                self.record = record
                self.descriptor = descriptor
                temporary_path.unlink()
                return self
            except FileExistsError:
                self._reclaim_stale_lock()
            finally:
                if not published:
                    fcntl.flock(descriptor, fcntl.LOCK_UN)
                    os.close(descriptor)
                    temporary_path.unlink(missing_ok=True)

    def release(self):
        if self.record is None:
            return
        try:
            if self._matches_path(self.descriptor):
                try:
                    record = json.loads(self.path.read_text())
                except (FileNotFoundError, json.JSONDecodeError):
                    record = None
                if record == self.record:
                    self.path.unlink(missing_ok=True)
        finally:
            fcntl.flock(self.descriptor, fcntl.LOCK_UN)
            os.close(self.descriptor)
            self.descriptor = None
            self.record = None

    def _reclaim_stale_lock(self):
        try:
            descriptor = os.open(self.path, os.O_RDONLY)
        except FileNotFoundError:
            return
        try:
            record = self._read_record(descriptor)
            if not self._valid_record(record):
                raise RuntimeError("dark-factory controller lock is malformed")
            if self._pid_is_live(record["pid"]):
                raise RuntimeError("dark-factory controller is already running")
            try:
                fcntl.flock(descriptor, fcntl.LOCK_EX | fcntl.LOCK_NB)
            except BlockingIOError as error:
                raise RuntimeError("dark-factory controller is already running") from error
            if not self._matches_path(descriptor):
                return
            record = self._read_record(descriptor)
            if not self._valid_record(record):
                raise RuntimeError("dark-factory controller lock is malformed")
            if self._pid_is_live(record["pid"]):
                raise RuntimeError("dark-factory controller is already running")
            self.path.unlink(missing_ok=True)
        finally:
            fcntl.flock(descriptor, fcntl.LOCK_UN)
            os.close(descriptor)

    def _matches_path(self, descriptor):
        try:
            path_status = self.path.stat()
        except FileNotFoundError:
            return False
        descriptor_status = os.fstat(descriptor)
        return (path_status.st_dev, path_status.st_ino) == (
            descriptor_status.st_dev,
            descriptor_status.st_ino,
        )

    @staticmethod
    def _write_all(descriptor, contents):
        while contents:
            written = os.write(descriptor, contents)
            if written <= 0:
                raise OSError("could not write controller lock record")
            contents = contents[written:]

    @staticmethod
    def _read_record(descriptor):
        os.lseek(descriptor, 0, os.SEEK_SET)
        try:
            record = json.loads(os.read(descriptor, 65536).decode())
        except (UnicodeDecodeError, json.JSONDecodeError):
            return None
        return record if isinstance(record, dict) else None

    @staticmethod
    def _valid_record(record):
        return (
            isinstance(record, dict)
            and isinstance(record.get("pid"), int)
            and not isinstance(record["pid"], bool)
            and record["pid"] > 0
            and isinstance(record.get("started_at"), str)
            and bool(record["started_at"].strip())
        )

    @staticmethod
    def _pid_is_live(pid):
        try:
            os.kill(pid, 0)
        except ProcessLookupError:
            return False
        except PermissionError:
            return True
        return True


class StartGate:
    def __init__(self, root):
        self.path = Path(root) / ".dark-factory" / "start.lock"
        self.held = False

    def __enter__(self):
        self.path.parent.mkdir(parents=True, exist_ok=True)
        try:
            descriptor = os.open(
                self.path, os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o600,
            )
        except FileExistsError:
            try:
                pid = int(self.path.read_text().strip())
                os.kill(pid, 0)
            except (FileNotFoundError, ProcessLookupError, ValueError):
                self.path.unlink(missing_ok=True)
                return self.__enter__()
            except PermissionError:
                pass
            raise RuntimeError("dark-factory controller start is already in progress")
        try:
            os.write(descriptor, f"{os.getpid()}\n".encode())
        finally:
            os.close(descriptor)
        self.held = True
        return self

    def __exit__(self, *unused):
        if self.held:
            self.path.unlink(missing_ok=True)
            self.held = False


def _state_for(root):
    return StateStore(Path(root))


def stop_controller(root):
    store = _state_for(root)
    state = store.load()
    state["updated_at"] = dt.datetime.now(dt.timezone.utc).isoformat()
    store.save(state, force_requested="stop")
    return 0


def monitor_controller(root):
    state = _state_for(root).load()
    wake = state.get("next_wake_at") or "none"
    issue = state.get("issue")
    issue_number = issue.get("number") if isinstance(issue, dict) else issue
    output = (
        f"{json.dumps(state, indent=2, sort_keys=True)}\n"
        f"phase: {state.get('phase', 'idle')}; "
        f"issue: {issue_number or 'none'}; next wake: {wake}"
    )
    print(output)
    return output


def _worker_command(root, issue=None, epic=None):
    command = [
        str(Path(__file__).resolve()),
        "run",
        "--workspace",
        str(Path(root).resolve()),
    ]
    if issue is not None:
        command.extend(["--issue", str(issue)])
    if epic is not None:
        command.extend(["--epic", str(epic)])
    return command


def start_controller(root, handshake_timeout=10, issue=None, epic=None):
    root = Path(root).resolve()
    if not (root / ".dark-factory" / "policy.json").is_file():
        raise RuntimeError(f"missing policy: {root / '.dark-factory' / 'policy.json'}")
    with StartGate(root):
        store = _state_for(root)
        state = store.load()
        worker_pid = state.get("worker_pid")
        worker_live = (
            isinstance(worker_pid, int)
            and not isinstance(worker_pid, bool)
            and ControllerLock._pid_is_live(worker_pid)
        )
        if state.get("requested") in ("starting", "running") and worker_live:
            raise RuntimeError("dark-factory controller is already running")
        state.update(
            requested="starting",
            worker_pid=None,
            startup_error=None,
            focus=_focus_dict(issue, epic),
        )
        store.save(state, force_requested="starting")
        process = subprocess.Popen(
            _worker_command(root, issue=issue, epic=epic),
            cwd=root,
            start_new_session=True,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        deadline = time.monotonic() + handshake_timeout
        while time.monotonic() < deadline:
            current = store.load()
            if (
                current.get("worker_pid") == process.pid
                and current.get("requested") in ("running", "stop")
            ):
                return 0
            if process.poll() is not None:
                break
            time.sleep(0.05)
        state = store.load()
        state.update(
            worker_pid=None,
            startup_error="worker did not publish PID handshake",
        )
        store.save(state, force_requested="stopped")
        raise RuntimeError("dark-factory worker failed to publish PID handshake")


def run_controller(root, issue=None, epic=None):
    root = Path(root).resolve()
    store = _state_for(root)
    with ControllerLock(root):
        state = store.load()
        if state.get("requested") == "stop":
            state.update(worker_pid=os.getpid(), phase="stopped")
            store.save(state)
            return 0
        state.update(
            requested="running",
            worker_pid=os.getpid(),
            focus=_focus_dict(issue, epic),
            updated_at=dt.datetime.now(dt.timezone.utc).isoformat(),
        )
        store.save(state, force_requested="running")
        while _controller_iteration(store, _gh_run):
            if store.load().get("requested") == "stop":
                continue
    return 0


def _gh_run(command):
    return subprocess.run(command, capture_output=True, text=True, check=False)


def dry_run_controller(root, run=_gh_run, issue=None, epic=None):
    root = Path(root).resolve()
    policy = load_policy(root)
    store = _state_for(root)
    state = store.load()
    selected, selection_summary = select_with_focus(
        run, policy, issue=issue, epic=epic,
    )
    focus = _focus_dict(issue, epic)
    if selected is None:
        state.update(
            requested="stopped",
            phase="idle",
            issue=None,
            focus=focus,
            dry_run_summary=f"dry-run: {selection_summary}",
            dry_run_prompt=None,
            updated_at=dt.datetime.now(dt.timezone.utc).isoformat(),
        )
        store.save(state, force_requested="stopped")
        print(state["dry_run_summary"])
        return 0
    selected = dict(selected, run_id=f"dry-run-{selected['number']}-{uuid.uuid4().hex[:8]}")
    prompt = build_phase_prompt(root, "planning", selected, "planner")
    summary = (
        f"dry-run: {selection_summary}; prepared {prompt}; "
        "no provider, PR, or merge commands ran"
    )
    state.update(
        requested="stopped",
        phase="dry_run",
        issue=selected,
        focus=focus,
        dry_run_prompt=str(prompt),
        dry_run_summary=summary,
        updated_at=dt.datetime.now(dt.timezone.utc).isoformat(),
    )
    store.save(state, force_requested="stopped")
    print(summary)
    return 0


def main(argv=None):
    arguments = list(sys.argv[1:] if argv is None else argv)
    if arguments and arguments[0] == "provider":
        if len(arguments) not in (5, 7):
            raise ValueError(
                "usage: dark-factory provider WORKSPACE PROVIDER PROMPT RUN_ID "
                "[--max-turns N]"
            )
        max_turns = 40
        if len(arguments) == 7:
            if arguments[5] != "--max-turns":
                raise ValueError("expected --max-turns")
            max_turns = int(arguments[6])
        result = run_provider(
            arguments[1],
            arguments[2],
            arguments[3],
            arguments[4],
            max_turns=max_turns,
        )
        return result.returncode

    parser = argparse.ArgumentParser(prog="dark-factory")
    parser.add_argument("action", choices=("start", "stop", "monitor", "run"))
    parser.add_argument("--workspace", default=".")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--issue", type=int)
    parser.add_argument("--epic", type=int)
    args = parser.parse_args(arguments)
    if args.dry_run and args.action != "run":
        parser.error("--dry-run is only valid with run")
    if args.issue is not None and args.epic is not None:
        parser.error("--issue and --epic are mutually exclusive")
    if (args.issue is not None or args.epic is not None) and args.action not in ("start", "run"):
        parser.error("--issue/--epic are only valid with start or run")
    root = Path(args.workspace).resolve()
    if args.action == "start":
        return start_controller(root, issue=args.issue, epic=args.epic)
    if args.action == "stop":
        return stop_controller(root)
    if args.action == "monitor":
        monitor_controller(root)
        return 0
    if args.dry_run:
        return dry_run_controller(root, issue=args.issue, epic=args.epic)
    return run_controller(root, issue=args.issue, epic=args.epic)


if __name__ == "__main__":
    try:
        sys.exit(main())
    except (RuntimeError, ValueError) as error:
        print(f"dark-factory: {error}", file=sys.stderr)
        sys.exit(1)
